<body class="bg-slate-50 text-slate-800 font-sans antialiased">

    <!-- 1. NAVIGATION BAR -->
    <nav class="sticky top-0 z-50 bg-slate-900/95 backdrop-blur-md text-white border-b border-slate-800 shadow-xl">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-20">
                <div class="flex items-center space-x-3">
                    <div class="p-2.5 bg-amber-500 rounded-xl shadow-lg shadow-amber-500/20">
                        <i class="fas fa-graduation-cap text-2xl text-slate-950"></i>
                    </div>
                    <div>
                        <span class="text-xl font-bold tracking-wider block">SMP NEGERI 4 TOJO</span>
                        <span class="text-xs text-amber-400 font-medium tracking-widest block uppercase">Cerdas & Berkarakter</span>
                    </div>
